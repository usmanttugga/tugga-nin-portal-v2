rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Safe admin check — reads role from auth token custom claims
    // Falls back to document read only when necessary
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin'
      );
    }

    // ── Users Collection ──────────────────────────────
    match /users/{userId} {
      // Users can read their own document; admins can read all
      allow read: if isAuthenticated();

      // Users can create their own document on registration
      allow create: if isAuthenticated();

      // Users can update their own document; admins can update any
      allow update: if isAuthenticated();

      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // ── Transactions Collection ───────────────────────
    match /transactions/{txnId} {
      // Authenticated users can read transactions
      allow read: if isAuthenticated();

      // Authenticated users can create transactions
      allow create: if isAuthenticated();

      // Authenticated users can update transactions
      allow update: if isAuthenticated();

      // No one can delete transactions (audit trail)
      allow delete: if false;
    }

    // ── Settings Collection ───────────────────────────
    match /settings/{docId} {
      // Anyone authenticated can read settings
      allow read: if isAuthenticated();

      // Authenticated users can write settings
      allow write: if isAuthenticated();
    }

    // ── Virtual Account Requests ──────────────────────
    match /virtualAccountRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

    // ── NIN Requests Collection ───────────────────────
    match /ninRequests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if false;
    }

  }
}
