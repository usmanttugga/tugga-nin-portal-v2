rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ── Users Collection ──────────────────────────────
    match /users/{userId} {
      // Users can read their own document; admins can read all
      allow read: if isOwner(userId) || isAdmin();

      // Users can create their own document on registration
      allow create: if isOwner(userId) && isAuthenticated();

      // Users can update their own document (except role); admins can update any
      allow update: if (isOwner(userId) && !('role' in request.resource.data.diff(resource.data).affectedKeys()))
                    || isAdmin();

      // Only admins can delete users
      allow delete: if isAdmin();
    }

    // ── Transactions Collection ───────────────────────
    match /transactions/{txnId} {
      // Users can read their own transactions; admins can read all
      allow read: if isAuthenticated() &&
                    (resource.data.userId == request.auth.uid || isAdmin());

      // Authenticated users can create transactions
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;

      // Only admins can update transaction status
      allow update: if isAdmin();

      // No one can delete transactions (audit trail)
      allow delete: if false;
    }

    // ── Settings Collection ───────────────────────────
    match /settings/{docId} {
      // Anyone authenticated can read settings
      allow read: if isAuthenticated();

      // Only admins can write settings
      allow write: if isAdmin();
    }

    // ── Virtual Account Requests ──────────────────────
    match /virtualAccountRequests/{requestId} {
      // Users can read their own requests; admins can read all
      allow read: if isAuthenticated() &&
                    (resource.data.userId == request.auth.uid || isAdmin());

      // Authenticated users can create requests
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;

      // Only admins can update (assign) virtual accounts
      allow update: if isAdmin();

      // No deletion
      allow delete: if false;
    }

    // ── NIN Requests Collection ───────────────────────
    match /ninRequests/{requestId} {
      allow read: if isAuthenticated() &&
                    (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
                      request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if false;
    }

  }
}
